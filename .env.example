# flipflop.statex.cz flipflop Platform - Environment Variables
# This file contains all environment variables for the platform
# DO NOT commit this file to version control

# =============================================================================
# Common Variables (All Services)
NODE_ENV=
SERVICE_NAME=

# Docker Compose Port Configuration
FRONTEND_PORT=
API_GATEWAY_PORT=
PRODUCT_SERVICE_PORT=
ORDER_SERVICE_PORT=
USER_SERVICE_PORT=
SUPPLIER_SERVICE_PORT=
AI_SERVICE_PORT=
ANALYTICS_SERVICE_PORT=
NGINX_NETWORK_NAME=

# Database Configuration
# Production database server: db-server-postgres (container name)
# Database is accessible via nginx-network Docker network
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SYNC=
DATABASE_URL=

# Redis Configuration
# Production Redis server: db-server-redis (container name)
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_DB=

# JWT Configuration
JWT_SECRET=
JWT_EXPIRES_IN=

# Service URLs
# Production website: https://flipflop.statex.cz
API_URL=
FRONTEND_URL=
CORS_ORIGIN=
USER_SERVICE_URL=
PRODUCT_SERVICE_URL=
ORDER_SERVICE_URL=

# Payments (payments-microservice) + checkout webhook
# PAYMENT_API_KEY must match one comma-separated entry in payments-microservice API_KEYS
API_GATEWAY_URL=
PAYMENT_SERVICE_URL=
PAYMENT_API_KEY=
# Optional: validate X-API-Key on inbound callbacks; use same value as payments SPEAKASAP_PORTAL_API_KEY
PAYMENT_WEBHOOK_API_KEY=
# Same secret on api-gateway and order-service (X-Flipflop-Internal-Key)
FLIPFLOP_INTERNAL_SERVICE_SECRET=

SUPPLIER_SERVICE_URL=
AI_SERVICE_URL=
ANALYTICS_SERVICE_URL=
NOTIFICATION_SERVICE_URL=http://notifications-microservice:3368
LOGGING_SERVICE_URL=

# PayU Payment Gateway Configuration

# OpenRouter AI Configuration

# SendGrid Email Configuration

# Telegram Configuration

# WhatsApp Configuration

# Frontend (Next.js) Public Variables
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_FRONTEND_URL=

# Logging Microservice Configuration
LOG_STORAGE_PATH=
LOG_ROTATION_MAX_SIZE=
LOG_ROTATION_MAX_FILES=
LOG_LEVEL=
LOG_TIMESTAMP_FORMAT=
LOG_FILE_PATH=
AUTH_SERVICE_URL=

# Cart Service Port
CART_SERVICE_PORT=

# Warehouse Service Port
WAREHOUSE_SERVICE_PORT=
WAREHOUSE_SERVICE_URL=

# Cancel pending-payment orders older than this many hours (stock unreserve); default 24

# Abandoned cart recovery e-mail: unpaid pending orders older than this many minutes; default 120
# How often the recovery job runs (minutes); default 30

# Cart Service URL
CART_SERVICE_URL=

DOMAIN=
ALLEGRO_DB_NAME=
TEST_LOGIN_EMAIL=
TEST_PASSWORD=

# Unified payments configuration
PAYMENT_APPLICATION_ID=
PAYMENT_CALLBACK_URL=
PAYMENT_SUCCESS_URL=
PAYMENT_CANCEL_URL=
